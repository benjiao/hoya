# Database
POSTGRES_DB=hoya
POSTGRES_USER=hoya
POSTGRES_PASSWORD=hoya
DATABASE_URL=postgres://hoya:hoya@db:5432/hoya

# API
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true
MEDIA_ROOT=/media
CSRF_TRUSTED_ORIGINS=https://hoya.benjiao.net

# Ports
DB_PORT=5432
API_PORT=8000
WEB_PORT=5173

# Volume paths (host-side)
# MEDIA_PATH=./media  # override to use a bind mount instead of the named volume

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
WATERING_INTERVAL_WINDOW=10

# Frontend
VITE_API_URL=http://localhost:8000/api/
VITE_ALLOWED_HOSTS=localhost