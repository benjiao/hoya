# Database
POSTGRES_DB=hoya
POSTGRES_USER=hoya
POSTGRES_PASSWORD=hoya
DATABASE_URL=postgres://hoya:hoya@db:5432/hoya

# API
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true
MEDIA_ROOT=/media

# Ports
DB_PORT=5432
API_PORT=8000
WEB_PORT=5173

# Volume paths (host-side)
API_SRC=./api
WEB_SRC=./web
# MEDIA_PATH=./media  # override to use a bind mount instead of the named volume

# Frontend
VITE_API_URL=http://localhost:8000/api/
